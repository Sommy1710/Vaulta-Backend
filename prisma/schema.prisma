generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ======================================================
// ADMIN SCHEMA
// ======================================================
enum AdminRole {
  ADMIN
}

model Admin {
  id String @id @default(cuid())

  username String @unique
  email    String @unique
  password String

  role AdminRole @default(ADMIN)

  isEmailVerified Boolean @default(false)

  emailVerificationCode String?
  emailCodeExpiry       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

// ======================================================
// USER SCHEMA
// ======================================================

model User {
  id String @id @default(uuid())

  firstname String
  lastname  String
  username  String @unique
  email     String @unique
  password  String

  isEmailVerified Boolean @default(false)

  role Role @default(USER)

  emailVerificationCode String?
  emailCodeExpiry       DateTime?

  passwordResetCode   String?
  passwordResetExpiry DateTime?

  isDeleted         Boolean   @default(false)
  deleteRequestedAt DateTime?

  singleSavings SingleSavings[]
  withdrawals   SingleSavingsWithdrawal[]

  createdDuoSavings      DuoSavings[]                  @relation("DuoSavingsCreator")
  duoSavingsParticipants DuoSavingsParticipant[]
  duoSavingsInvites      DuoSavingsInvite[]
  duoWithdrawalRequests  DuoSavingsWithdrawalRequest[]

  createdFamilySavings      FamilySavings[]                  @relation("FamilySavingsCreator")
  familySavingsParticipants FamilySavingsParticipant[]
  familySavingsInvites      FamilySavingsInvite[]
  familyWithdrawalRequests  FamilySavingsWithdrawalRequest[]
  reports                   Report[]

  conversations Conversation[]
  

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

// ======================================================
// SINGLE SAVINGS SCHEMA
// ======================================================

enum PlanType {
  SINGLE
}

enum SavingsStatus {
  PENDING
  ACTIVE
  MATURED
  WITHDRAWN
}

enum WithdrawalStatus {
  SUCCESSFUL
}

model SingleSavings {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstname String
  lastname  String
  username  String

  planType PlanType @default(SINGLE)

  amountSaved  Float
  interestRate Float @default(10)

  expectedInterest Float
  totalPayout      Float

  startDate    DateTime @default(now())
  maturityDate DateTime

  status SavingsStatus @default(ACTIVE)

  lastCompoundedAt DateTime?

  withdrawals SingleSavingsWithdrawal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("single_savings")
}

model SingleSavingsWithdrawal {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  savingsPlanId String
  savingsPlan   SingleSavings @relation(fields: [savingsPlanId], references: [id], onDelete: Cascade)

  amount Float

  WalletType    WalletType?
  walletAddress String?

  status WithdrawalStatus @default(SUCCESSFUL)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("single_savings_withdrawals")
}

// ======================================================
// DUO SAVINGS SCHEMA
// ======================================================

enum DuoInviteStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum DuoWithdrawalRequestStatus {
  PENDING
  APPROVED
  REJECTED
  EXECUTED
}

enum DuoSavingsStatus {
  PENDING
  ACTIVE
  MATURED
  WITHDRAWN
}

model DuoSavings {
  id String @id @default(cuid())

  createdById String

  createdBy User @relation("DuoSavingsCreator", fields: [createdById], references: [id], onDelete: Cascade)

  amountSaved Float @default(0)

  interestRate Float @default(15)

  expectedInterest Float @default(0)

  totalPayout Float @default(0)

  startDate DateTime @default(now())

  maturityDate DateTime

  status DuoSavingsStatus @default(ACTIVE)

  lastCompoundedAt DateTime?

  participants DuoSavingsParticipant[]

  invites DuoSavingsInvite[]

  withdrawalRequests DuoSavingsWithdrawalRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("duo_savings")
}

model DuoSavingsParticipant {
  id String @id @default(cuid())

  duoSavingsId String

  duoSavings DuoSavings @relation(fields: [duoSavingsId], references: [id], onDelete: Cascade)

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  contribution Float @default(0)

  joinedAt DateTime @default(now())

  @@unique([duoSavingsId, userId])
  @@map("duo_savings_participants")
}

model DuoSavingsInvite {
  id String @id @default(cuid())

  duoSavingsId String
  duoSavings   DuoSavings @relation(fields: [duoSavingsId], references: [id], onDelete: Cascade)

  invitedUserId String
  invitedUser   User   @relation(fields: [invitedUserId], references: [id], onDelete: Cascade)

  status DuoInviteStatus @default(PENDING)

  createdAt DateTime @default(now())

  @@unique([duoSavingsId, invitedUserId])
  @@map("duo_savings_invites")
}

model DuoSavingsWithdrawalRequest {
  id String @id @default(cuid())

  duoSavingsId String
  duoSavings   DuoSavings @relation(fields: [duoSavingsId], references: [id], onDelete: Cascade)

  requestedById String
  requestedBy   User   @relation(fields: [requestedById], references: [id], onDelete: Cascade)

  amount Float

  WalletType    WalletType?
  walletAddress String?

  creatorApproved Boolean @default(false)

  partnerApproved Boolean @default(false)

  status DuoWithdrawalRequestStatus @default(PENDING)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@map("duo_savings_withdrawal_requests")
}

// ======================================================
// FAMILY SAVINGS SCHEMA
// ======================================================

enum FamilyInviteStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum FamilyWithdrawalRequestStatus {
  PENDING
  APPROVED
  REJECTED
  EXECUTED
}

enum FamilySavingsStatus {
  PENDING
  ACTIVE
  MATURED
  WITHDRAWN
}

enum WalletType {
  BITCOIN
  ETHEREUM
}

model FamilySavings {
  id String @id @default(cuid())

  createdById String

  createdBy User @relation("FamilySavingsCreator", fields: [createdById], references: [id], onDelete: Cascade)

  amountSaved Float @default(0)

  interestRate Float @default(30)

  expectedInterest Float @default(0)

  totalPayout Float @default(0)

  startDate DateTime @default(now())

  maturityDate DateTime

  status FamilySavingsStatus @default(ACTIVE)

  lastCompoundedAt DateTime?

  participants FamilySavingsParticipant[]

  invites FamilySavingsInvite[]

  withdrawalRequests FamilySavingsWithdrawalRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("family_savings")
}

model FamilySavingsParticipant {
  id String @id @default(cuid())

  familySavingsId String

  familySavings FamilySavings @relation(fields: [familySavingsId], references: [id], onDelete: Cascade)

  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  contribution Float @default(0)

  joinedAt DateTime @default(now())

  @@unique([familySavingsId, userId])
  @@map("family_savings_participants")
}

model FamilySavingsInvite {
  id String @id @default(cuid())

  familySavingsId String
  familySavings   FamilySavings @relation(fields: [familySavingsId], references: [id], onDelete: Cascade)

  invitedUserId String
  invitedUser   User   @relation(fields: [invitedUserId], references: [id], onDelete: Cascade)

  status FamilyInviteStatus @default(PENDING)

  createdAt DateTime @default(now())

  @@unique([familySavingsId, invitedUserId])
  @@map("family_savings_invites")
}

model FamilySavingsWithdrawalRequest {
  id String @id @default(cuid())

  familySavingsId String
  familySavings   FamilySavings @relation(fields: [familySavingsId], references: [id], onDelete: Cascade)

  requestedById String
  requestedBy   User   @relation(fields: [requestedById], references: [id], onDelete: Cascade)

  amount Float

  WalletType    WalletType?
  walletAddress String?

  creatorApproved Boolean @default(false)

  partnerApproved Boolean @default(false)

  status FamilyWithdrawalRequestStatus @default(PENDING)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@map("family_savings_withdrawal_requests")
}

// ======================================================
// REPORT A PROBLEM
// ======================================================

enum ReportCategory {
  ACCOUNT
  PAYMENT
  SINGLE_SAVINGS
  DUO_SAVINGS
  FAMILY_SAVINGS
  WITHDRAWAL
  SECURITY
  OTHER
}

enum ReportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model Report {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  category ReportCategory

  subject String

  description String @db.Text

  status ReportStatus @default(OPEN)

  adminResponse String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reports")
}

// ======================================================
// MESSAGE SCHEMA
// ======================================================

model Conversation {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status ConversationStatus @default(OPEN)

  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Message {
  id String @id @default(cuid())

  conversationId String
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderType SenderType

  message String @db.Text

  isRead Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SenderType {
  USER
  ADMIN
}

enum ConversationStatus {
  OPEN
  CLOSED
}
